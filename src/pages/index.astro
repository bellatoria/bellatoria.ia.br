---
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Bellatoria</title>
    <meta
      name="description"
      content="Bellatoria reune guias, leituras e historias em uma biblioteca digital."
    />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body data-page-slug="home" data-section="home" data-page-type="home">
    <div class="site-shell">
      <header class="masthead wrap">
        <nav class="navbar">
          <a class="brand" href="/">
            <span class="brand-mark">BI</span>
            <span class="brand-copy">
              <strong>Bellatoria</strong>
              <span>Guias, leituras e historias</span>
            </span>
          </a>
          <div class="nav-links">
            <a href="/agora/">Agora</a>
            <a href="/guides/">Guias</a>
            <a href="/stories/">Historias</a>
            <a href="/explore/">Explorar</a>
            <a href="/about">Sobre</a>
          </div>
        </nav>
      </header>

      <main>
        <section class="hero wrap">
          <div class="hero-grid">
            <article class="panel">
              <span class="kicker">Bellatoria</span>
              <h1>Uma biblioteca digital para leitura, referencia e descoberta.</h1>
              <p class="lead">
                O site reune paginas de entrada, guias e historias em uma estrutura simples.
              </p>
              <div class="hero-actions">
                <a class="button primary" href="/guides/">Abrir Guias</a>
                <a class="button secondary" href="/explore/">Explorar secoes</a>
              </div>
            </article>
            <aside class="panel">
              <span class="kicker">Secoes</span>
              <div class="signal-list">
                <div class="signal-item">
                  <strong>Agora</strong>
                  <span>Paginas de entrada e orientacao.</span>
                </div>
                <div class="signal-item">
                  <strong>Guias</strong>
                  <span>Referencias e caminhos de leitura.</span>
                </div>
                <div class="signal-item">
                  <strong>Historias</strong>
                  <span>Espaco reservado para narrativas e atmosfera.</span>
                </div>
              </div>
            </aside>
          </div>
        </section>

        <section class="section wrap">
          <div class="section-header">
            <span class="eyebrow">Entradas</span>
            <div class="section-title">
              <h2>Quatro caminhos simples.</h2>
              <p>As secoes abaixo funcionam como pontos de acesso para o acervo atual.</p>
            </div>
          </div>
          <div class="card-grid">
            <article class="card">
              <small>Agora</small>
              <h3><a href="/agora/">Entradas e orientacao</a></h3>
              <p>Textos curtos para abrir um assunto ou indicar um primeiro passo.</p>
            </article>
            <article class="card">
              <small>Guias</small>
              <h3><a href="/guides/">Guias e referencias</a></h3>
              <p>Paginas de consulta e leitura organizada por tema.</p>
            </article>
            <article class="card">
              <small>Historias</small>
              <h3><a href="/stories/">Narrativa e atmosfera</a></h3>
              <p>Secao reservada para textos mais literarios e experimentais.</p>
            </article>
            <article class="card">
              <small>Explorar</small>
              <h3><a href="/explore/">Explorar o acervo</a></h3>
              <p>Navegacao mais aberta por assunto e tipo de leitura.</p>
            </article>
          </div>
        </section>
      </main>

      <footer class="footer">
        <div class="wrap">
          <div class="footer-nav">
            <a href="/about">Sobre</a>
            <a href="/legal/">Legal</a>
            <a href="/guides/">Guias</a>
            <a href="/stories/">Historias</a>
          </div>
          <p class="footer-note">Bellatoria.</p>
        </div>
      </footer>
    </div>
    <script is:inline src="/analytics.js"></script>
  </body>
</html>
